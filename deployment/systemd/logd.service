[Unit]
Description=read-only log server (list/tail/grep ~/log over TCP, no ssh)
Requires=network-online.target
After=network-online.target

[Service]
EnvironmentFile=/etc/environment
ExecStart=/home/vq-user/server/logd.py
Restart=always
RestartSec=10
StartLimitBurst=5
User=vq-user
WorkingDirectory=/home/vq-user/server
StandardOutput=append:/home/vq-user/log/logd.log
StandardError=append:/home/vq-user/log/logd.log

[Install]
WantedBy=multi-user.target
